# Root .gitignore for CureNet

# Project specific docs and context to ignore
COMPLETE_PROJECT_CONTEXT.md
MIDTERM_REPORT.md
CURENET_MINOR_PROJECT_REPORT.md
PRESENTATION_NOTES.md
Documentation/
*.pdf
*.docx
*.xlsx
curenet/report.js
curenet.zip

# Local Secrets & Environment
.env
.env.local
.env.*.local
curenet/.env
curenet/.env.example
secrets.json

# System / IDE files
.DS_Store
.idea/
*.iml
*.ipr
*.iws
.vscode/

# General Flutter/Dart ignores (Recursive)
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
coverage/

# Mobile specific build artifacts
/android/app/debug
/android/app/profile
/android/app/release
app.*.symbols
app.*.map.json
*.keystore
*.jks
**/google-services.json
**/GoogleService-Info.plist

# Logs and temporary files
*.log
*.bak
*.swp
*~

# Node.js (report.js dependencies)
node_modules/
package-lock.json
