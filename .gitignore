# Root .gitignore for CureNet

# ─── Generated Output & Test Data ──────────────────────────────────────
curenet/backend/output_bundles/
curenet/backend/uploads/
curenet/backend/ocr_scan_result.json
curenet/backend/scratch_doc.txt
Implementation_Guide_for_Adoption_of_FHIR_in_ABDM_and_NHCX (1).pdf

# ─── Binary Data (too large for git) ──────────────────────────────────
*.traineddata

# ─── Local Secrets & Environment ──────────────────────────────────────
.env
.env.local
.env.*.local
secrets.json

# ─── Academic Docs (tracked separately) ───────────────────────────────
*.pdf
*.docx
*.xlsx
Documentation/

# ─── System / IDE files ──────────────────────────────────────────────
.DS_Store
.idea/
*.iml
*.ipr
*.iws
.vscode/

# ─── Flutter / Dart ──────────────────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
coverage/

# ─── Mobile Build Artifacts ──────────────────────────────────────────
/android/app/debug
/android/app/profile
/android/app/release
app.*.symbols
app.*.map.json
*.keystore
*.jks
**/google-services.json
**/GoogleService-Info.plist

# ─── Logs & Temp ─────────────────────────────────────────────────────
*.log
*.bak
*.swp
*~

# ─── Node.js ─────────────────────────────────────────────────────────
node_modules/
